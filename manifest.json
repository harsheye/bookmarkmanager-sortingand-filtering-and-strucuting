{
  "manifest_version": 3,
  "name": "Smart Bookmark Organizer",
  "version": "1.0.0",
  "description": "Toggle a floating Command Center overlay on any web page (Alt+Shift+A) to browse, search, and manage bookmarks Raycast-style.",
  "permissions": [
    "bookmarks",
    "storage",
    "activeTab",
    "scripting",
    "cookies",
    "history"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Bookmark Organizer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "rules.js",
        "content.js"
      ]
    }
  ],
  "commands": {
    "toggle-command-center": {
      "suggested_key": {
        "default": "Alt+A",
        "mac": "Alt+A"
      },
      "description": "Toggle the Bookmark Command Center overlay"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
